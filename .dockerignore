# build artifacts
node_modules/
dist/
dist-ssr/
coverage/
coverage-out/

# version control
.git/
.github/

# claude agent config
.claude/

# test and doc sources — not needed for the production image
tests/
docs/

# scripts/ is kept in the build context because the build step now invokes
# `tsx scripts/compress-dist.ts` to pre-compress dist/ assets. Other scripts
# (e.g. fetch-quran.ts) are devtime-only and harmless to include.

# deployment config
deploy/

# environment secrets
.env
.env.*

# editor / OS noise
.vscode/
.idea/
.DS_Store
*.log

# human-facing docs — not needed inside the image
README.md
CLAUDE.md
